# Copy to ~/Library/Application Support/Trening/credentials/.env and fill in.
# NEVER commit this file with real values.

# Garmin Connect (brukes kun ved førstegangs-innlogging + MFA; etter det bruker
# python-garminconnect cached tokens i garmin_tokens.json)
GARMIN_EMAIL=
GARMIN_PASSWORD=

# Withings — opprett dev-app på developer.withings.com
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=
WITHINGS_REDIRECT_URI=http://localhost:8080/callback

# Concept2 — opprett dev-app på log-dev.concept2.com
CONCEPT2_CLIENT_ID=
CONCEPT2_CLIENT_SECRET=
CONCEPT2_REDIRECT_URI=http://localhost:8080/callback

# Telegram Bot (opprett via @BotFather, send deretter en melding til boten for å hente chat_id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# Yazio — opprett konto i mobil-appen (iOS/Android), logg noen måltider
YAZIO_EMAIL=
YAZIO_PASSWORD=

# Yazio OAuth client — reverse-engineered fra Yazio-appen. Disse er
# felles for alle Yazio-brukere (ikke personlige). Finn dem i community-
# klienter som dimensi/yazio eller juriadams/yazio (src/utils/constants.ts).
YAZIO_CLIENT_ID=
YAZIO_CLIENT_SECRET=
